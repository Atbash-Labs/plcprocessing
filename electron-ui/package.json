{
  "name": "plc-ontology-assistant",
  "version": "1.0.0",
  "description": "PLC Ontology Assistant - Knowledge graph management for PLC systems",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "dist": "electron-builder --win",
    "dist:dir": "electron-builder --win --dir"
  },
  "license": "MIT",
  "dependencies": {},
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.plcprocessing.ontology-assistant",
    "productName": "PLC Ontology Assistant",
    "directories": {
      "output": "../dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "graph-renderer.js",
      "index.html",
      "styles.css"
    ],
    "extraResources": [
      {
        "from": "../build/python-backend",
        "to": "python-backend",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "dir",
          "arch": ["x64"]
        }
      ],
      "icon": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}













